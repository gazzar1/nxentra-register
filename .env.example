# === Database ===
DATABASE_URL=postgresql://nxentra:nxentra@db:5432/nxentra

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Django ===
DJANGO_SECRET_KEY=change-me-in-production
# A162: DEBUG defaults False — dev must set True explicitly; production
# must set False and every "required in production" var below.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Required True in production (asserted at boot, A162).
PROJECTIONS_SYNC=True
# Required in production (error reporting, A123/A163):
# SENTRY_DSN=

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Email (Postmark) ===
# POSTMARK_SERVER_TOKEN=

# === Shopify ===
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_WEBHOOK_SECRET=

# === OpenAI (voice parsing) ===
# OPENAI_API_KEY=

# === Field encryption at rest (A47) — REQUIRED in production ===
# Encrypts provider credentials (Shopify tokens, Stripe webhook secret + read
# key). Comma-separated Fernet keys; first encrypts, all decrypt (rotation).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=
