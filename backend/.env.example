# backend/.env.example — copy to backend/.env and fill in.
#
# A162: DEBUG defaults FALSE. Dev machines MUST set DEBUG=True here or the
# production guards refuse to boot (SECRET_KEY/FIELD_ENCRYPTION_KEY/CORS
# hard-fails, HTTPS redirect, Secure cookies). Production MUST set
# DEBUG=False and every "REQUIRED in production" var below.

# --- Core -------------------------------------------------------------
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Database / broker --------------------------------------------------
# Omitting DATABASE_URL falls back to a local SQLite file (dev only).
# DATABASE_URL=postgresql://nxentra:password@localhost:5432/nxentra
# REQUIRED in production (Celery broker + result backend):
# REDIS_URL=redis://localhost:6379/0

# --- Projections ----------------------------------------------------------
# REQUIRED True in production — asserted at boot (A162): accounting
# commands read projected rows synchronously after emitting events.
PROJECTIONS_SYNC=True

# --- Observability ----------------------------------------------------------
# REQUIRED in production (error reporting + alert rules, A123/A163):
# SENTRY_DSN=

# --- Field encryption at rest (A47) — REQUIRED in production ----------------
# Encrypts provider credentials (Shopify tokens, Stripe webhook secret +
# read key). Comma-separated Fernet keys; first encrypts, all decrypt
# (rotation). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=
